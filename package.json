{
  "name": "documind-ai-document-q-a-platform",
  "private": true,
  "version": "1.0.0",
  "description": "DocuMind is a full-stack AI document Q&A platform with RAG, citations, streaming chat, and multi-document comparison.",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "build": "npm --prefix frontend run build",
    "lint": "npm --prefix frontend run lint"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
